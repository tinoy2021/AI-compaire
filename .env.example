# Choose which API runs visual comparison (required if you have keys for both)
# Values: gemini | openai
# AI_PROVIDER=gemini

# Google Gemini — get a key from https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_key_here
# Premium-quality default uses Pro first (gemini-2.5-pro). Override if needed:
# GEMINI_MODEL=gemini-2.5-pro
# Or comma-separated fallback order:
# GEMINI_MODELS=gemini-2.5-pro,gemini-2.5-flash,gemini-2.0-flash
# (alias supported)
# GOOGLE_API_KEY=your_key_here

# OpenAI — get a key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Optional model (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# How many unique same-origin pages to visit per site when collecting hyperlinks (default 1 = entry URL only).
# Increase (e.g. 50) to discover links across more of each site.
# CRAWL_MAX_PAGES=50
